# DutchDeck — environment variables
# Copy this file to `.env` and fill in your own values:  cp .env.example .env
# NEVER commit your real .env — it is gitignored.

# ─── Supabase (Node scripts / card-generation pipeline) ───
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Supabase (Vite frontend / PWA) ───
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Shared secret for the PWA <-> Edge Function calls (any random string)
VITE_DD_API_TOKEN=your-random-app-token

# ─── Anthropic Claude (flashcard generation) ───
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# ─── ElevenLabs (per-card text-to-speech audio) ───
ELEVENLABS_API_KEY=your-elevenlabs-key
# Default below is ElevenLabs' public "Rachel" voice; swap for any voice you like.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ─── Card-generation pipeline tuning ───
DECK_PATH=./your-seed-deck.apkg
BATCH_SIZE=20
BATCH_DELAY_MS=2000
